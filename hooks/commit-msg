#!/usr/bin/env python3
"""
commit-msg hook — validates the Step-4 discharge artifact for rule-corpus commits.

Per anneal-framework development-process.md step 4 (release loop):
- Detects if the commit touches rule-corpus files (spec/, development-process.md,
  instantiation-guide.md, foundation.md, post-run-review.md, plugin/skills/,
  instance-template/)
- If so, requires a Step-4 discharge artifact in the commit message
- Validates each of the 7 required checks is present
- Pattern-fails on rationalize-away-as-covered shapes ("folded into",
  "subsumed by", "covered by [other check]") — per the closed-set rule
  shipped in commit df61abc
- Pattern-warns on judgment-based N/A reasons without mechanical citation

Checkpoint carve-out: a first-line prefix `anneal-checkpoint:` marks an
anneal-dev per-unit IMPLEMENT checkpoint commit (a working-progress save
for resume, per the framework Checkpoint discipline), NOT a release
commit. The Step-4 discharge gates the RELEASE commit (operator-approved,
pushed); checkpoint commits skip it — the discharge cannot be honestly
produced mid-implement (verify is downstream). Parallel to the
Merge/Revert/fixup skip below. (development-process.md: checkpoint-save
is not the release-commit the discharge gates.)

Bypass: `git commit --no-verify` (visible in audit; explicit operator
action required).
"""

import re
import subprocess
import sys
from pathlib import Path

# Optional `anneal-dev/` prefix: after the anneal-dev↔anneal-framework
# merge (corpus-flows-redesign D5), anneal-dev's rule-corpus lives at
# `anneal-dev/{spec,plugin/skills,.claude-plugin}/…` within this repo. The
# `^`-anchored patterns must match that relocated location too, or the
# merged instance's rule-corpus commits bypass the discharge gate (D9).
RULE_CORPUS_PATTERN = re.compile(
    r"^(anneal-dev/)?(spec/.+\.md|development-process\.md|post-run-review\.md|"
    r"instantiation-guide\.md|foundation\.md|plugin/skills/.+\.md|"
    r"instance-template/.+\.md|"
    r"\.claude-plugin/.+|plugin/\.claude-plugin/.+)$"
)

# Instance plugin render path — plugin/skills/<not-skill-craft>/*.
# Skill-craft canonical (plugin/skills/skill-craft/) is exempt because
# skill-craft IS source, not render (meta-plugin where canonical files
# are the source). Optional `anneal-dev/` prefix per the merge (D9).
INSTANCE_PLUGIN_PATTERN = re.compile(r"^(anneal-dev/)?plugin/skills/(?!skill-craft/)[^/]+/.+\.md$")

# Method-kernel SOURCE files — the set whose edit is a method-kernel edit.
# Mirrors hooks/anneal-dev-run-gate.py's KERNEL_PATTERNS (that file's
# suffix-anchored `/spec/.+\.md$`, `/foundation\.md$`, etc.) in this hook's
# repo-relative `^`-anchored idiom; `(anneal-dev/)?` covers anneal-dev/spec/*
# and anneal-dev/{foundation,development-process,...}.md post-merge, exactly
# as RULE_CORPUS_PATTERN above. A commit touching one of these is a
# method-kernel edit, so the discharge must carry the Foundation-invariant
# check line (development-process.md step 4). NARROW + additive: this does NOT
# broaden RULE_CORPUS_PATTERN — it is a separate, additional check.
KERNEL_SOURCE_PATTERN = re.compile(
    r"^(anneal-dev/)?(spec/.+\.md|foundation\.md|development-process\.md|"
    r"post-run-review\.md|instantiation-guide\.md)$"
)

# A registered foundation-invariant entry file (dev-notes/foundation-invariants/
# INV-<n>-<slug>.md). README.md and archive/ under that folder are EXEMPT — only
# the INV-*.md entry files are the registered invariants. Used with
# `git diff --cached --name-status --diff-filter=MD` so only MODIFIES/DELETES of
# an existing invariant trip the marker; ADDITIONS of new INV files do not
# (adding a check does not weaken the foundation). NARROW + additive.
INVARIANT_FILE_PATTERN = re.compile(
    r"^dev-notes/foundation-invariants/INV-.+\.md$"
)

REQUIRED_CHECKS = [
    "Render fidelity",
    "Practice-4 dependent audit",
    "Skill-craft full review on changed skill files",
    "Skill-craft self-review on framework-spec section",
    "Skill-craft self-review on commits to skill-craft canonical files",
    "Practice-6 whole-document coherence",
    "Cross-spec multi-file coherence",
]

# Required only when commit touches instance plugin renders (per
# development-process.md practice 5 "Spec-origin grounding for plugin
# edits" + contract 2 "Render completeness").
SPEC_ORIGIN_CHECK = "Spec-origin trace"

# Required only when the commit touches a method-kernel SOURCE file
# (KERNEL_SOURCE_PATTERN) — per development-process.md step 4, a method-kernel
# edit's discharge must carry the Foundation-invariant check. Parallel to
# SPEC_ORIGIN_CHECK (required only when instance-plugin files are touched).
# HONESTY (per the locked design): the hook checks the LINE IS PRESENT — that
# the focusing artifact was produced + presented. It does NOT and cannot
# enforce the soundness judgment; that is the operator's, via the step-4
# approval. A green pass on a kernel-source commit means "artifact present",
# never "sound".
FOUNDATION_INVARIANT_CHECK = "Foundation-invariant check"

# The line printed on a PASSING kernel-source commit — disclaims soundness so
# the green pass is not misread as a soundness certification.
FOUNDATION_INVARIANT_PASS_NOTE = (
    "foundation-invariant check: focusing artifact present — NOT a soundness "
    "certification; operator soundness verdict required"
)

FOLD_INTO_PATTERNS = [
    re.compile(r"folded into", re.IGNORECASE),
    re.compile(r"subsumed by", re.IGNORECASE),
    re.compile(
        r"covered by\s+(other (check|reviewer|subagent)|"
        r"render[- ]?fidelity|cross[- ]?spec|skill[- ]?craft|prior)",
        re.IGNORECASE,
    ),
]

JUDGMENT_NA_PATTERNS = [
    re.compile(r"\bsmall change\b", re.IGNORECASE),
    re.compile(r"prior reviewer covers", re.IGNORECASE),
    re.compile(r"\bwell[- ]grounded\b", re.IGNORECASE),
    re.compile(r"in[- ]context should be enough", re.IGNORECASE),
    re.compile(r"\bI judged\b", re.IGNORECASE),
    re.compile(r"\bjudged.{0,20}redundant\b", re.IGNORECASE),
    re.compile(r"\bthis is a small\b", re.IGNORECASE),
]

NA_LINE_PATTERN = re.compile(r"N/A:", re.IGNORECASE)


def red(s: str) -> str:
    return f"\033[31m{s}\033[0m"


def green(s: str) -> str:
    return f"\033[32m{s}\033[0m"


def yellow(s: str) -> str:
    return f"\033[33m{s}\033[0m"


def get_changed_files() -> list[str]:
    """Files staged for commit (cached)."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True,
        text=True,
        check=True,
    )
    return [f for f in result.stdout.splitlines() if f]


def is_rule_corpus_commit(files: list[str]) -> tuple[bool, list[str]]:
    """True if any file in diff matches rule-corpus patterns."""
    matching = [f for f in files if RULE_CORPUS_PATTERN.match(f)]
    return bool(matching), matching


def has_kernel_source_files(files: list[str]) -> tuple[bool, list[str]]:
    """True if any staged file is a method-kernel SOURCE file (the set that
    makes the commit a method-kernel edit)."""
    matching = [f for f in files if KERNEL_SOURCE_PATTERN.match(f)]
    return bool(matching), matching


def get_modified_deleted_invariant_files() -> list[str]:
    """Staged files that MODIFY (M) or DELETE (D) an existing registered
    invariant entry (INV-*.md). Uses `--diff-filter=MD` so ADDITIONS (A) of new
    INV files are excluded — adding a check does not weaken the foundation.
    README.md / archive/ are excluded by INVARIANT_FILE_PATTERN."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-status", "--diff-filter=MD"],
        capture_output=True,
        text=True,
        check=True,
    )
    matched = []
    for entry in result.stdout.splitlines():
        if not entry:
            continue
        # name-status lines: "<STATUS>\t<path>" (M/D have a single path).
        parts = entry.split("\t")
        path = parts[-1]
        if INVARIANT_FILE_PATTERN.match(path):
            matched.append(path)
    return matched


def has_instance_plugin_files(files: list[str]) -> tuple[bool, list[str]]:
    """True if any file is an instance plugin render (excluding skill-craft canonical)."""
    matching = [f for f in files if INSTANCE_PLUGIN_PATTERN.match(f)]
    return bool(matching), matching


def validate_discharge(msg: str) -> list[str]:
    """Run all discharge-artifact validations. Returns list of error messages."""
    errors = []

    # 1. Discharge present
    if "Step-4 discharge" not in msg:
        errors.append(
            "Missing Step-4 discharge artifact in commit message.\n"
            "  See development-process.md step 4 for the required template.\n"
            "  Format: 'Step-4 discharge for commit [pending]:' followed by\n"
            "  one line per check in [subagent ID, verdict] / [N/A: ...] / "
            "[in-context check cited] form."
        )
        return errors  # No point checking further if discharge absent

    # 2. All required checks listed
    missing_checks = [c for c in REQUIRED_CHECKS if c not in msg]
    if missing_checks:
        errors.append(
            f"Discharge artifact missing required checks:\n"
            + "\n".join(f"    - {c}" for c in missing_checks)
        )

    # 2a. Spec-origin trace required for instance plugin commits
    # (per development-process.md practice 5 + contract 2).
    if SPEC_ORIGIN_CHECK not in msg:
        # Re-check files: this validation only fires when instance plugin
        # files are in the diff.
        changed = get_changed_files()
        has_plugin, plugin_files = has_instance_plugin_files(changed)
        if has_plugin:
            errors.append(
                f"Commit touches instance plugin render files:\n"
                + "\n".join(f"    - {f}" for f in plugin_files)
                + "\n  Discharge artifact missing required check:\n"
                f"    - {SPEC_ORIGIN_CHECK} (per development-process.md\n"
                f"      practice 5 'Spec-origin grounding for plugin edits'\n"
                f"      and contract 2 'Render completeness')."
            )

    # 2b. Foundation-invariant check required for method-kernel-edit commits
    # (per development-process.md step 4). Fires only when a method-kernel
    # SOURCE file is in the diff — parallel to the spec-origin check above.
    # The line confirms the focusing artifact was PRODUCED + PRESENTED; the
    # soundness judgment remains the operator's (step-4 approval).
    if FOUNDATION_INVARIANT_CHECK not in msg:
        changed = get_changed_files()
        has_kernel, kernel_files = has_kernel_source_files(changed)
        if has_kernel:
            errors.append(
                f"Commit touches method-kernel SOURCE files:\n"
                + "\n".join(f"    - {f}" for f in kernel_files)
                + "\n  Discharge artifact missing required check:\n"
                f"    - {FOUNDATION_INVARIANT_CHECK} (per development-process.md\n"
                f"      step 4 — a method-kernel edit's discharge must carry the\n"
                f"      per-touched-invariant holds/violates focusing artifact).\n"
                f"  NOTE: this checks the artifact is PRESENT, not that the edit\n"
                f"  is sound — the soundness verdict is the operator's (step-4\n"
                f"  approval), never this hook's."
            )

    # 3. No fold-into rationalizations
    fold_into_hits = []
    for pat in FOLD_INTO_PATTERNS:
        for m in pat.finditer(msg):
            line_start = msg.rfind("\n", 0, m.start()) + 1
            line_end = msg.find("\n", m.end())
            if line_end == -1:
                line_end = len(msg)
            line = msg[line_start:line_end]
            fold_into_hits.append(line.strip())

    if fold_into_hits:
        errors.append(
            "Fold-into rationalization detected (per development-process.md "
            "step 4, 'A \"folded-into\" or \"subsumed\" form is never one of "
            "those — it is the rationalize-away-as-covered shape'):\n"
            + "\n".join(f"    {l}" for l in fold_into_hits)
        )

    # 4. Judgment-based N/A reasons (warn, not block — secondary heuristic)
    warnings = []
    lines = msg.splitlines()
    for i, line in enumerate(lines):
        if NA_LINE_PATTERN.search(line):
            # Check this line and the next 2 for judgment patterns
            window = "\n".join(lines[i : i + 3])
            for jpat in JUDGMENT_NA_PATTERNS:
                if jpat.search(window):
                    warnings.append(
                        f"Possible judgment-based N/A near line {i + 1}: '{line.strip()}'"
                    )
                    break

    if warnings:
        print(yellow("WARNINGS (not blocking):"))
        for w in warnings:
            print(yellow(f"  ⚠ {w}"))
        print(yellow(
            "  N/A reasons must cite mechanical evidence "
            "(paths, grep, diff fragments)."
        ))
        print()

    return errors


INVARIANT_RATIFIED_MARKER = "Invariant-change-ratified:"


def check_invariant_marker(msg: str) -> int | None:
    """D4 — Invariant-change-ratified marker (audit-trail + friction, NOT a
    binding gate). When the staged diff MODIFIES (M) or DELETES (D) an existing
    registered invariant (INV-*.md), the commit message must carry an
    `Invariant-change-ratified:` line. Returns 1 (block) if such a file is
    staged and the marker is absent; None otherwise (no M/D invariant, or marker
    present — fall through). ADDITIONS of new INV files are exempt (filtered out
    by --diff-filter=MD); README.md / archive/ are exempt (INVARIANT_FILE_PATTERN).

    This is a separate, additive check — independent of the rule-corpus
    discharge path (an INV-*.md under dev-notes/ is not a rule-corpus file), so
    it runs before the discharge early-out."""
    md_invariants = get_modified_deleted_invariant_files()
    if not md_invariants:
        return None  # no M/D of a registered invariant — not in scope
    if INVARIANT_RATIFIED_MARKER in msg:
        print(green(
            f"✓ {INVARIANT_RATIFIED_MARKER} marker present for invariant "
            f"modify/delete ({len(md_invariants)} file(s))."
        ))
        return None
    print(red("✗ Registered-invariant modify/delete without ratification marker:"))
    print()
    for f in md_invariants:
        print(red(f"    - {f}"))
    print()
    print(red(
        f"  This commit MODIFIES or DELETES a registered foundation invariant.\n"
        f"  Weakening or removing a registered invariant must be a deliberate,\n"
        f"  ratification-CLAIMING, logged act — add an\n"
        f"  '{INVARIANT_RATIFIED_MARKER} <operator-approval-ref>' line to the\n"
        f"  commit message.\n"
        f"\n"
        f"  This is an audit-trail + friction mechanism, NOT a binding gate: it\n"
        f"  is bypassable with `git commit --no-verify` (by design), and a hook\n"
        f"  cannot verify an operator actually approved. The binding is\n"
        f"  AI-discipline + the operator's review catching a bogus claim."
    ))
    print()
    return 1


def main() -> int:
    msg_file = Path(sys.argv[1])
    msg = msg_file.read_text()

    # Skip merges, reverts, fixups, and anneal-dev implement checkpoints.
    # `anneal-checkpoint:` is a per-unit working-progress save (resume
    # point), not the release commit the discharge gates — the discharge
    # cannot be produced mid-implement (verify is downstream).
    first_line = msg.splitlines()[0] if msg.splitlines() else ""
    if first_line.startswith(
        ("Merge ", "Revert ", "fixup!", "squash!", "amend!", "anneal-checkpoint:")
    ):
        return 0

    # D4 — Invariant-change-ratified marker. Independent of the rule-corpus
    # discharge below (an INV-*.md under dev-notes/ is not a rule-corpus file),
    # so it is checked first, on its own. Blocks on M/D of a registered
    # invariant without the marker.
    if check_invariant_marker(msg) == 1:
        return 1

    changed = get_changed_files()
    is_corpus, corpus_files = is_rule_corpus_commit(changed)

    if not is_corpus:
        # No rule-corpus files — discharge not required
        return 0

    print(f"Rule-corpus commit detected ({len(corpus_files)} file(s)):")
    for f in corpus_files:
        print(f"  - {f}")
    print()

    errors = validate_discharge(msg)

    if errors:
        print(red("✗ Discharge artifact validation FAILED:"))
        print()
        for err in errors:
            print(red(f"  {err}"))
            print()
        print(red(
            "Commit blocked. Fix the discharge artifact and re-commit.\n"
            "Bypass (visible in audit): git commit --no-verify"
        ))
        return 1

    print(green("✓ Discharge artifact validation passed."))

    # D3b — when this is a method-kernel-edit commit that PASSED, the green
    # signal must NOT read as a soundness certification. Disclaim it explicitly:
    # the hook confirmed the focusing artifact is PRESENT, not that the edit is
    # sound (the operator's step-4 soundness verdict is the irreducible gate).
    has_kernel, _ = has_kernel_source_files(corpus_files)
    if has_kernel:
        print(green(f"  {FOUNDATION_INVARIANT_PASS_NOTE}"))

    return 0


if __name__ == "__main__":
    sys.exit(main())
